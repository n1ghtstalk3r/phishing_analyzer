def kom(ws, r, c, v, fill=None, fc='000000', sz=10, bold=False, align='left', w=None, wrap=False):
    cell = ws.cell(row=r, column=c, value=oczysc_xml(v) if isinstance(v, str) else v)
    cell.font      = Font(name='Arial', bold=bold, color=fc, size=sz)
    cell.alignment = Alignment(horizontal=align, vertical='center', wrap_text=wrap)
    if fill: cell.fill = fill
    cell.border = brd
    if w: ws.column_dimensions[get_column_letter(c)].width = w
    return cell

def nagl(ws, r, c, v, fill=None, w=None):
    if fill is None: fill = HDR
    return kom(ws, r, c, v, fill=fill, fc='FFFFFF', sz=11, bold=True, align='center', w=w)

def scal(ws, r, c1, c2, v, fill, fc='FFFFFF', sz=13):
