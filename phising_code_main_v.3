def sprawdz_whois(domena):
    try:
        d = domena_glowna(domena)
        w = whois.whois(d)
        creation = w.creation_date
        if isinstance(creation, list): creation = creation[0]
        if creation:
            if creation.tzinfo is None: creation = creation.replace(tzinfo=timezone.utc)
            wiek_dni = (datetime.now(timezone.utc) - creation).days
            rejestr  = w.registrar or "?"
            if wiek_dni < 30:
                return {"zrodlo": "WHOIS", "wynik": f"{wiek_dni} dni", "ocena": "ZŁOŚLIWY",
                        "szczegoły": f"ŚWIEŻA DOMENA ({wiek_dni} dni)! Rejestrator: {rejestr}"}
            elif wiek_dni < 180:
                return {"zrodlo": "WHOIS", "wynik": f"{wiek_dni} dni", "ocena": "PODEJRZANY",
                        "szczegoły": f"Młoda domena ({wiek_dni} dni). Rejestrator: {rejestr}"}
            else:
                return {"zrodlo": "WHOIS", "wynik": f"{wiek_dni} dni", "ocena": "CZYSTY",
                        "szczegoły": f"Wiek: {wiek_dni} dni. Rejestrator: {rejestr}"}
        return {"zrodlo": "WHOIS", "wynik": "Brak daty", "ocena": "NIEZNANY",
                "szczegoły": "Nie udało się pobrać daty rejestracji — DO WERYFIKACJI"}
    except Exception as e:
        return {"zrodlo": "WHOIS", "wynik": str(e), "ocena": "BŁĄD", "szczegoły": "Błąd WHOIS — DO WERYFIKACJI"}

def sprawdz_dns(domena):
    d      = domena_glowna(domena)
    wyniki = []
    oceny  = []
    try:
        odp         = dns.resolver.resolve(d, "TXT")
        rekordy_spf = [r.to_text().strip('"') for r in odp if "v=spf1" in r.to_text()]
        if rekordy_spf:
            spf = rekordy_spf[0]
            wyniki.append(f"SPF: {spf[:80]}")
            if   "+all" in spf: wyniki.append("⚠ SPF +all — KAŻDY moze wysylac! Krytyczne!"); oceny.append("ZŁOŚLIWY")
            elif "?all" in spf: wyniki.append("⚠ SPF ?all — brak polityki");                  oceny.append("PODEJRZANY")
            elif "~all" in spf: wyniki.append("~ SPF ~all — softfail");                        oceny.append("PODEJRZANY")
            elif "-all" in spf: wyniki.append("✓ SPF -all — hardfail, bezpieczne");            oceny.append("CZYSTY")
            else:               wyniki.append("⚠ SPF bez mechanizmu all");                     oceny.append("PODEJRZANY")
        else:
            wyniki.append("✗ SPF: BRAK rekordu"); oceny.append("PODEJRZANY")
    except:
        wyniki.append("✗ SPF: blad zapytania DNS"); oceny.append("BŁĄD")
    try:
        odp           = dns.resolver.resolve(f"_dmarc.{d}", "TXT")
        rekordy_dmarc = [r.to_text().strip('"') for r in odp if "v=DMARC1" in r.to_text()]
        if rekordy_dmarc:
            dmarc = rekordy_dmarc[0]
            wyniki.append(f"DMARC: {dmarc[:80]}")
            if   "p=none"       in dmarc: wyniki.append("⚠ DMARC p=none — tylko monitoring");      oceny.append("PODEJRZANY")
            elif "p=quarantine" in dmarc: wyniki.append("~ DMARC p=quarantine — idzie do spamu"); oceny.append("CZYSTY")
            elif "p=reject"     in dmarc: wyniki.append("✓ DMARC p=reject — falszywe odrzucane"); oceny.append("CZYSTY")
            else:                          wyniki.append("⚠ DMARC bez polityki p=");               oceny.append("PODEJRZANY")
            if "rua=" not in dmarc: wyniki.append("⚠ DMARC bez rua= — brak raportowania")
        else:
            wyniki.append("✗ DMARC: BRAK rekordu"); oceny.append("PODEJRZANY")
    except:
        wyniki.append("✗ DMARC: BRAK rekordu"); oceny.append("PODEJRZANY")
    try:
        mx      = dns.resolver.resolve(d, "MX")
        serwery = [r.exchange.to_text() for r in mx]
        wyniki.append(f"MX: {', '.join(serwery[:2])}")
    except:
        wyniki.append("✗ MX: BRAK — domena nie przyjmuje poczty"); oceny.append("PODEJRZANY")
    priorytety = {"ZŁOŚLIWY": 3, "PODEJRZANY": 2, "CZYSTY": 0, "BŁĄD": -1}
    ocena_fin  = max(oceny, key=lambda x: priorytety.get(x, -1)) if oceny else "CZYSTY"
    return {"zrodlo": "DNS", "wynik": "SPF/DMARC/MX", "ocena": ocena_fin, "szczegoły": " | ".join(wyniki)}

def sprawdz_tld(domena):
    for tld in PODEJRZANE_TLD:
        if domena.endswith(tld):
            return {"zrodlo": "TLD", "wynik": tld,  "ocena": "PODEJRZANY", "szczegoły": f"Podejrzany TLD: {tld}"}
    return         {"zrodlo": "TLD", "wynik": "OK", "ocena": "CZYSTY",     "szczegoły": "TLD nie jest podejrzany"}

def sprawdz_typosquatting(domena):
    d         = domena_glowna(domena).lower().replace("-", ".").replace("_", ".")
    czlony    = d.split(".")
    trafienia = [m for m in ZNANE_MARKI if m in czlony and d not in [f"{m}.pl", f"{m}.com", f"{m}.org", f"{m}.net"]]
    if trafienia:
        return {"zrodlo": "Typosquatting", "wynik": ", ".join(trafienia), "ocena": "ZŁOŚLIWY",
                "szczegoły": f"Domena podszywa sie pod: {', '.join(trafienia)}"}
    return     {"zrodlo": "Typosquatting", "wynik": "OK", "ocena": "CZYSTY",
                "szczegoły": "Nie wykryto typosquattingu"}

def sprawdz_tor(ip):
    try:
        addr = ip_address(ip)
        for cidr in TOR_EXIT_CIDR:
            if addr in ip_network(cidr):
                return {"zrodlo": "Tor Check", "wynik": "TOR EXIT NODE", "ocena": "ZŁOŚLIWY",
                        "szczegoły": f"IP nalezy do zakresu Tor: {cidr}"}
        return {"zrodlo": "Tor Check", "wynik": "Nie Tor", "ocena": "CZYSTY", "szczegoły": "Nie jest Tor exit node"}
    except Exception as e:
        return {"zrodlo": "Tor Check", "wynik": str(e), "ocena": "BŁĄD", "szczegoły": "Błąd sprawdzania Tor — DO WERYFIKACJI"}

def sprawdz_geolokalizacje(ip):
    try:
        r = requests.get(
            f"http://ip-api.com/json/{ip}?fields=country,countryCode,city,isp,org,as,proxy,hosting",
            timeout=5, verify=False
        )
        if r.status_code == 200:
            d       = r.json()
            proxy   = d.get("proxy", False)
            hosting = d.get("hosting", False)
            kraj    = d.get("country", "?")
            miasto  = d.get("city", "?")
            flagi   = []
            if proxy:   flagi.append("PROXY")
            if hosting: flagi.append("HOSTING/VPS")
            return {
                "zrodlo":    "GeoIP",
                "wynik":     f"{kraj}, {miasto}",
                "ocena":     "PODEJRZANY" if (proxy or hosting) else "CZYSTY",
                "szczegoły": f"Kraj: {kraj}, Miasto: {miasto}, Org: {d.get('org','?')}, ASN: {d.get('as','?')}" +
                             (f", Flagi: {', '.join(flagi)}" if flagi else "")
            }
        return {"zrodlo": "GeoIP", "wynik": f"Błąd {r.status_code}", "ocena": "BŁĄD",
                "szczegoły": f"HTTP {r.status_code} — brak danych"}
    except Exception as e:
        return {"zrodlo": "GeoIP", "wynik": str(e), "ocena": "BŁĄD",
                "szczegoły": "Błąd połączenia GeoIP — DO WERYFIKACJI"}

def sprawdz_naglowki_auth(linie):
    wyniki = []; oceny = []
    received_spf = ""; auth_results = []; arc_auth = []; arc_seals = []; arc_sigs = []

    naglowki_raw = []; bufor = ""
    for linia in linie:
        if linia[0:1] in (" ", "\t") and bufor:
            bufor += " " + linia.strip()
        else:
            if bufor: naglowki_raw.append(bufor)
            bufor = linia.strip()
    if bufor: naglowki_raw.append(bufor)

    for n in naglowki_raw:
        if n.startswith("Received-SPF:") or n.startswith("received-spf:"):
            received_spf = n.split(":", 1)[1].strip()
        if n.startswith("Authentication-Results:") or n.startswith("authentication-results:"):
            auth_results.append(n.split(":", 1)[1].strip())
        if n.startswith("ARC-Authentication-Results:") or n.startswith("arc-authentication-results:"):
            arc_auth.append(n.split(":", 1)[1].strip())
        if n.startswith("ARC-Seal:") or n.startswith("arc-seal:"):
            arc_seals.append(n.split(":", 1)[1].strip())
        if n.startswith("ARC-Message-Signature:") or n.startswith("arc-message-signature:"):
            arc_sigs.append(n.split(":", 1)[1].strip())

    if received_spf:
        wyniki.append(f"Received-SPF: {received_spf[:100]}")
        rspf = received_spf.lower()
        if   "pass"      in rspf: wyniki.append("✓ SPF pass — serwer autoryzowany");           oceny.append("CZYSTY")
        elif "softfail"  in rspf: wyniki.append("~ SPF softfail — podejrzane");                 oceny.append("PODEJRZANY")
        elif "fail"      in rspf: wyniki.append("✗ SPF FAIL — serwer NIEAUTORYZOWANY!");        oceny.append("ZŁOŚLIWY")
        elif "none"      in rspf: wyniki.append("⚠ SPF none — brak polityki SPF");              oceny.append("PODEJRZANY")
        elif "neutral"   in rspf: wyniki.append("⚠ SPF neutral — brak jednoznacznej polityki"); oceny.append("PODEJRZANY")
        elif "temperror" in rspf or "permerror" in rspf:
            wyniki.append("✗ SPF ERROR — błąd weryfikacji SPF!"); oceny.append("BŁĄD")
    else:
        wyniki.append("⚠ Brak nagłówka Received-SPF — DO WERYFIKACJI"); oceny.append("PODEJRZANY")

    if auth_results:
        for ar in auth_results[:2]:
            arl = ar.lower()
            wyniki.append(f"Auth-Results: {ar[:120]}")
            if   "dkim=pass"      in arl: wyniki.append("✓ DKIM pass — podpis zweryfikowany");              oceny.append("CZYSTY")
            elif "dkim=fail"      in arl: wyniki.append("✗ DKIM FAIL — podpis NIEPRAWIDŁOWY!");              oceny.append("ZŁOŚLIWY")
            elif "dkim=none"      in arl: wyniki.append("⚠ DKIM none — brak podpisu DKIM");                 oceny.append("PODEJRZANY")
            elif "dkim=permerror" in arl: wyniki.append("✗ DKIM permerror — błąd weryfikacji");             oceny.append("BŁĄD")
            if   "dmarc=pass"     in arl: wyniki.append("✓ DMARC pass — polityka spełniona");               oceny.append("CZYSTY")
            elif "dmarc=fail"     in arl: wyniki.append("✗ DMARC FAIL — wiadomość NIE przeszła DMARC!");    oceny.append("ZŁOŚLIWY")
            elif "dmarc=none"     in arl: wyniki.append("⚠ DMARC none — brak polityki DMARC");              oceny.append("PODEJRZANY")
            if   "spf=pass"       in arl: wyniki.append("✓ SPF pass (Auth-Results)");                       oceny.append("CZYSTY")
            elif "spf=fail"       in arl: wyniki.append("✗ SPF fail (Auth-Results)");                       oceny.append("ZŁOŚLIWY")
            if   "compauth=pass"  in arl: wyniki.append("✓ Composite Auth pass (Microsoft)");               oceny.append("CZYSTY")
            elif "compauth=fail"  in arl: wyniki.append("✗ Composite Auth FAIL (Microsoft)!");              oceny.append("ZŁOŚLIWY")
    else:
        wyniki.append("⚠ Brak nagłówka Authentication-Results — DO WERYFIKACJI"); oceny.append("PODEJRZANY")

    if arc_seals or arc_auth:
        wyniki.append("--- ARC (Authenticated Received Chain) ---")
        wszystkie_cv = []
        for seal in arc_seals:
            cv_match = re.search(r"cv=(\w+)", seal, re.IGNORECASE)
            if cv_match:
                cv = cv_match.group(1).lower(); wszystkie_cv.append(cv)
                i_match = re.search(r"\bi=(\d+)", seal, re.IGNORECASE)
                i_val   = i_match.group(1) if i_match else "?"
                d_match = re.search(r"\bd=([a-zA-Z0-9.\-]+)", seal)
                d_val   = d_match.group(1) if d_match else "?"
                if   cv == "none": wyniki.append(f"  ARC-Seal i={i_val} cv=none — pierwszy węzeł ({d_val})");     oceny.append("CZYSTY")
                elif cv == "pass": wyniki.append(f"  ARC-Seal i={i_val} cv=pass — węzeł zweryfikowany ({d_val})"); oceny.append("CZYSTY")
                elif cv == "fail": wyniki.append(f"  ✗ ARC-Seal i={i_val} cv=FAIL — łańcuch ZEPSUTY ({d_val})!");  oceny.append("ZŁOŚLIWY")

        i_vals = []
        for seal in arc_seals:
            i_match = re.search(r"\bi=(\d+)", seal, re.IGNORECASE)
            if i_match: i_vals.append(int(i_match.group(1)))
        if i_vals:
            i_vals_sorted = sorted(i_vals); oczekiwane = list(range(1, len(i_vals)+1))
            if i_vals_sorted == oczekiwane:
                wyniki.append(f"✓ ARC łańcuch spójny — {len(i_vals)} węzłów: {i_vals_sorted}"); oceny.append("CZYSTY")
            else:
                wyniki.append(f"✗ ARC łańcuch NIESPÓJNY — numery i={i_vals_sorted}!"); oceny.append("ZŁOŚLIWY")

        for arc_ar in arc_auth[:2]:
            arc_arl = arc_ar.lower()
            i_match = re.search(r"\bi=(\d+)", arc_ar, re.IGNORECASE)
            i_val   = i_match.group(1) if i_match else "?"
            wyniki.append(f"  ARC-Auth-Results i={i_val}: {arc_ar[:100]}")
            if "spf=fail"   in arc_arl: wyniki.append(f"  ✗ ARC i={i_val}: oryginalny SPF=FAIL");   oceny.append("ZŁOŚLIWY")
            if "dkim=fail"  in arc_arl: wyniki.append(f"  ✗ ARC i={i_val}: oryginalny DKIM=FAIL");  oceny.append("ZŁOŚLIWY")
            if "dmarc=fail" in arc_arl: wyniki.append(f"  ✗ ARC i={i_val}: oryginalny DMARC=FAIL"); oceny.append("ZŁOŚLIWY")

        if len(arc_sigs) != len(arc_seals) and arc_seals:
            wyniki.append(f"⚠ Niezgodna liczba ARC-Seal ({len(arc_seals)}) i ARC-Message-Signature ({len(arc_sigs)})")
            oceny.append("PODEJRZANY")
        if not any(cv == "fail" for cv in wszystkie_cv):
            wyniki.append("✓ ARC — żaden węzeł nie zgłosił cv=fail")
    else:
        wyniki.append("~ Brak nagłówków ARC (normalny przy bezpośredniej dostawie, podejrzany przy forwardowaniu)")

    priorytety = {"ZŁOŚLIWY": 3, "PODEJRZANY": 2, "CZYSTY": 0, "BŁĄD": -1}
    ocena_fin  = max(oceny, key=lambda x: priorytety.get(x, -1)) if oceny else "CZYSTY"
    return {"zrodlo": "Auth/ARC Headers", "wynik": "SPF/DKIM/DMARC/ARC", "ocena": ocena_fin,
            "szczegoły": " | ".join(wyniki)}

def sprawdz_tresc(tekst, subject, from_, reply_to):
    wyniki = []; tekst_lower = tekst.lower(); subject_lower = subject.lower()
    znalezione = [s for s in PILNE_SLOWA if s in tekst_lower or s in subject_lower]
    if znalezione: wyniki.append(f"Pilne frazy: {', '.join(znalezione[:3])}")
    match_nazwa = re.match(r'^"?([^"<]+)"?\s*<([^>]+)>', from_.strip())
    if match_nazwa:
        nazwa_wyswietlana = match_nazwa.group(1).strip().lower()
        adres_email       = match_nazwa.group(2).strip()
        domena_nadawcy    = adres_email.split('@')[1].lower() if '@' in adres_email else ''
        d_glowna_nadawcy  = domena_glowna(domena_nadawcy)
        for marka in ZNANE_MARKI:
            if marka in nazwa_wyswietlana.replace(" ", "").replace("-", ""):
                if marka not in d_glowna_nadawcy:
                    wyniki.append(f'SPOOFING NAZWY: "{match_nazwa.group(1).strip()}" sugeruje {marka.upper()}, ale domena to {domena_nadawcy}')
                    break
    from_domena    = re.search(r"@([\w.\-]+)", from_)
    replyto_domena = re.search(r"@([\w.\-]+)", reply_to)
    if from_domena and replyto_domena:
        if domena_glowna(from_domena.group(1)) != domena_glowna(replyto_domena.group(1)):
            wyniki.append(f"NIEZGODNOSC From/Reply-To: {from_domena.group(1)} vs {replyto_domena.group(1)}")
    linki = re.findall(r"https?://[^\s<>\"]+", tekst)
    if len(linki) > 3: wyniki.append(f"Duzo linkow w tresci: {len(linki)} szt.")
    for link in linki:
        for tld in PODEJRZANE_TLD:
            if tld in link:
                wyniki.append(f"Podejrzany TLD w linku: {link[:60]}"); break
    skracacze_w_tresci = [l for l in linki if czy_skracacz(l)]
    if skracacze_w_tresci:
        wyniki.append(f"Skracacze URL w treści: {', '.join(skracacze_w_tresci[:3])}")
    ocena = "ZŁOŚLIWY" if len(wyniki) >= 2 else ("PODEJRZANY" if wyniki else "CZYSTY")
    return {"zrodlo": "Analiza tresci", "wynik": f"{len(wyniki)} sygnałów", "ocena": ocena,
            "szczegoły": " | ".join(wyniki) if wyniki else "Brak podejrzanych sygnałów"}

