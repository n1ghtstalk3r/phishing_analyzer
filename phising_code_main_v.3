print("\n===== DOMENY Z URL (nagłówki + body) =====")

domeny     = []
urls       = []
url_zrodla = {}

for linia in linie:
    for url in re.findall(r"https?://[^\s<>\"']+", linia):
        url = url.rstrip(".,;)")
