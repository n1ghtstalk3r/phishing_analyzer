    "v.gd", "0rz.tw", "tny.im", "p.ly", "hyperurl.co",
}

def czy_skracacz(url: str) -> bool:
    try:
        m = re.match(r"https?://([a-zA-Z0-9.\-]+)", url)
        if m:
            return m.group(1).lower() in SKRACACZE_URL
    except:
        pass
    return False


def rozwin_url(url: str) -> str:
    """
    Rozwija skracacze URL podążając za przekierowaniami.
    Używać wyłącznie na izolowanym środowisku (brudas itp.).
    """
    try:
        resp = requests.head(
            url,
            allow_redirects=True,
            timeout=10,
            verify=False,
            headers={"User-Agent": "Mozilla/5.0"}
        )
        rozwiniety = resp.url
        if rozwiniety != url:
            print(f"      ↳ Rozwinięto: {url[:60]} → {rozwiniety[:60]}")
        return rozwiniety
    except Exception as e:
        print(f"      ⚠ Błąd rozwijania: {e}")
        return url

# ════════════════════════════════════════
# Wyciąganie URLi z BODY maila
# ════════════════════════════════════════
URL_REGEX = re.compile(r"https?://[^\s<>\"'\]\[)(\}{\|\\^`]+", re.IGNORECASE)

def _wyciagnij_url_z_tekstu(tekst):
    znalezione = []
    for url in URL_REGEX.findall(tekst):
        url = url.rstrip(".,;:!?)\"'")
        if len(url) > 8 and url not in znalezione:
            znalezione.append(url)
    return znalezione

def dekoduj_base64_chunk(tekst):
    try:
        czysty  = re.sub(r'\s+', '', tekst)
        padding = len(czysty) % 4
        if padding:
            czysty += '=' * (4 - padding)
        zdekodowane = base64.b64decode(czysty)
        for enc in ('utf-8', 'latin-1', 'cp1250'):
            try:
                return zdekodowane.decode(enc)
            except:
                continue
    except:
        pass
    return None

def dekoduj_quoted_printable(tekst):
    try:
        return quopri.decodestring(tekst.encode('ascii', errors='replace')).decode('utf-8', errors='replace')
    except:
        return tekst

def _wyciagnij_urle_z_tnef(raw_bytes, dodaj_fn):
    if not TNEF_DOSTEPNY:
        return
    try:
        tnef = tnefparse.TNEF(raw_bytes, do_checksum=False)
    except Exception as e:
        print(f"  ⚠ Błąd parsowania TNEF: {e}")
        return

    def dekoduj(val):
        if isinstance(val, bytes):
            for enc in ('utf-8', 'latin-1', 'cp1250'):
                try: return val.decode(enc)
                except: continue
        return str(val) if val else ''

    if tnef.rtfbody:
        rtf_str = dekoduj(tnef.rtfbody)
        for url in re.findall(r'HYPERLINK\s+"(https?://[^"]+)"', rtf_str, re.IGNORECASE):
            dodaj_fn(url, "TNEF/RTF HYPERLINK")
            print(f"    ★ TNEF RTF HYPERLINK: {url[:80]}")
        for url in _wyciagnij_url_z_tekstu(rtf_str):
            dodaj_fn(url, "TNEF/RTF body")

    if tnef.htmlbody:
        html_str = dekoduj(tnef.htmlbody)
        for url in _wyciagnij_url_z_tekstu(html_str):
            dodaj_fn(url, "TNEF/HTML body")
            print(f"    ★ TNEF HTML: {url[:80]}")

    if tnef.body:
        body_str = dekoduj(tnef.body)
        for url in _wyciagnij_url_z_tekstu(body_str):
            dodaj_fn(url, "TNEF/body (plain)")

    for att in getattr(tnef, 'attachments', []):
        att_name = ''
        try: att_name = att.long_filename or att.name or ''
        except: pass
        for attr in getattr(att, 'attrs', []):
            try:
                val = attr.data if hasattr(attr, 'data') else None
                if val is None: continue
                val_str = dekoduj(val)
                if 'http' in val_str.lower():
                    for url in _wyciagnij_url_z_tekstu(val_str):
                        dodaj_fn(url, f"TNEF/załącznik [{att_name or 'brak nazwy'}]")
            except:
                pass


def wyciagnij_urle_z_body():
    wyniki   = []
    widziane = set()

    def dodaj(url, zrodlo):
        url = url.rstrip(".,;:!?)\"'")
        if url not in widziane and len(url) > 8:
            widziane.add(url)
            wyniki.append((url, zrodlo))

    if FORMAT == ".msg" and _msg_obj:
        if _msg_obj.body:
            for url in _wyciagnij_url_z_tekstu(_msg_obj.body):
                dodaj(url, "MSG/body (plain)")
        html = _msg_obj.htmlBody
        if html:
            if isinstance(html, bytes):
                html = html.decode('utf-8', errors='replace')
            for url in _wyciagnij_url_z_tekstu(html):
                dodaj(url, "MSG/body (HTML)")
        rtf = _msg_obj.rtfBody
        if rtf:
            if isinstance(rtf, bytes):
                rtf = rtf.decode('latin-1', errors='replace')
            for url in re.findall(r'HYPERLINK\s+"(https?://[^"]+)"', rtf, re.IGNORECASE):
                dodaj(url, "MSG/RTF HYPERLINK")
            for url in _wyciagnij_url_z_tekstu(rtf):
                dodaj(url, "MSG/RTF body")
        try:
            deenc = _msg_obj.deencapsulatedRtf
            if deenc:
                html_rtf = deenc.html if hasattr(deenc, 'html') else str(deenc)
                for url in _wyciagnij_url_z_tekstu(html_rtf):
                    dodaj(url, "MSG/RTF deencapsulated")
        except:
            pass
        for att in _msg_obj.attachments:
            try:
                att_data = att.data
                att_name = (att.longFilename or att.shortFilename or "").lower()
                if att_data and isinstance(att_data, bytes):
                    ext = att_name.rsplit('.', 1)[-1] if '.' in att_name else ''
                    if ext in ('html', 'htm', 'txt', 'rtf') or len(att_data) < 200_000:
                        tekst = att_data.decode('utf-8', errors='replace')
                        for url in _wyciagnij_url_z_tekstu(tekst):
                            dodaj(url, f"MSG/załącznik [{att_name or 'brak'}]")
            except:
                pass
        return wyniki

    if FORMAT == ".eml" and _mime_obj:
        for part in _mime_obj.walk():
            if part.is_multipart():
                continue
            ct    = (part.get_content_type() or '').lower()
            cte   = (part.get('Content-Transfer-Encoding') or '').lower().strip()
            fname = (part.get_filename() or '').lower()
            cs    = part.get_content_charset() or 'utf-8'
            if 'ms-tnef' in ct or 'winmail.dat' in fname:
                pb = part.get_payload(decode=True)
                if pb:
                    print(f"  ★ EML zawiera winmail.dat ({len(pb)} B) — parsowanie TNEF")
                    _wyciagnij_urle_z_tnef(pb, dodaj)
                continue
            try:
                pb = part.get_payload(decode=True)
                if pb:
                    tekst_czesci = pb.decode(cs, errors='replace')
                    etykieta = f"MIME {ct}"
                    if cte == 'base64':          etykieta += " [Base64]"
                    elif cte == 'quoted-printable': etykieta += " [QP]"
                    for url in _wyciagnij_url_z_tekstu(tekst_czesci):
                        dodaj(url, etykieta)
            except:
                pass
        return wyniki

    tekst_pelny = raw.decode('utf-8', errors='replace')
    czesci = re.split(r'(?i)content-transfer-encoding\s*:\s*base64', tekst_pelny)
    for czesc in czesci[1:]:
        blok    = re.split(r'\n--|\nContent-', czesc, maxsplit=1)[0]
        linie_b = blok.strip().splitlines()
        start   = next((j+1 for j, l in enumerate(linie_b) if l.strip() == ''), 0)
        zdek    = dekoduj_base64_chunk('\n'.join(linie_b[start:]))
        if zdek:
            for url in _wyciagnij_url_z_tekstu(zdek):
                dodaj(url, "Base64-body (fallback)")
    qp_sekcje = re.split(r'(?i)content-transfer-encoding\s*:\s*quoted-printable', tekst_pelny)
    for czesc in qp_sekcje[1:]:
        blok    = re.split(r'\n--|\nContent-', czesc, maxsplit=1)[0]
        linie_b = blok.strip().splitlines()
        start   = next((j+1 for j, l in enumerate(linie_b) if l.strip() == ''), 0)
        zdek    = dekoduj_quoted_printable('\n'.join(linie_b[start:]))
        for url in _wyciagnij_url_z_tekstu(zdek):
            dodaj(url, "QuotedPrintable-body (fallback)")
    for url in _wyciagnij_url_z_tekstu(tekst_pelny):
        dodaj(url, "Plaintext")
    return wyniki


