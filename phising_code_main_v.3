def ocena_zbiorcza(wyniki_lista):
    priorytety = {"ZŁOŚLIWY": 3, "PODEJRZANY": 2, "CZYSTY": 0}
    if not wyniki_lista:
        return "BRAK DANYCH - DO WERYFIKACJI"
    bledy  = [w for w in wyniki_lista if w["ocena"] in ("BŁĄD", "NIEZNANY")]
    dobre  = [w for w in wyniki_lista if w["ocena"] not in ("BŁĄD", "NIEZNANY")]
    suffix = " — DO WERYFIKACJI" if bledy else ""
    if not dobre:
        return "BRAK DANYCH - DO WERYFIKACJI"
    najgorsza = max(dobre, key=lambda x: priorytety.get(x["ocena"], -1))["ocena"]
    return f"{najgorsza}{suffix}"

def kolor_oceny(ocena):
    baza = ocena.split(" —")[0].strip()
    fc, fill = {
        "ZŁOŚLIWY":                     ("C00000", PatternFill('solid', start_color='FFE0E0')),
        "PODEJRZANY":                   ("BF8F00", PatternFill('solid', start_color='FFF2CC')),
        "CZYSTY":                       ("375623", PatternFill('solid', start_color='E2EFDA')),
        "NIEZNANY":                     ("595959", PatternFill('solid', start_color='F2F2F2')),
        "BŁĄD":                         ("595959", PatternFill('solid', start_color='F2F2F2')),
        "BRAK DANYCH - DO WERYFIKACJI": ("7030A0", PatternFill('solid', start_color='EAD1FF')),
    }.get(baza, ("000000", PatternFill('solid', start_color='FFFFFF')))
    if "DO WERYFIKACJI" in ocena and baza != "BRAK DANYCH - DO WERYFIKACJI":
        fill = PatternFill('solid', start_color='F3E6FF')
    return fc, fill

