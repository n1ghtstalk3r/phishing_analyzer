def sekcja(ws, row, tytul, kolor):
    ws.row_dimensions[row].height = 22
    scal(ws, row, 1, 4, tytul, kolor, sz=11)
    return row + 1

def wiersz(ws, row, kolumna, sygnal, opis, ocena):
    ws.row_dimensions[row].height = 30
    fc_kol, fill = kolor_oceny(ocena)
    kom(ws, row, 1, kolumna, GRY,  bold=True, align='center', wrap=True)
    kom(ws, row, 2, sygnal,  fill, bold=True, fc=fc_kol, wrap=True)
    kom(ws, row, 3, opis,    GRY2, wrap=True)
    kom(ws, row, 4, ocena,   fill, bold=True, fc=fc_kol, align='center')
    return row + 1

