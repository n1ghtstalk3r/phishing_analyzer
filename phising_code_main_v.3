_cache_mxt = {}

def _mxt_lookup(komenda, argument):
    if not MXTOOLBOX_KEY:
        return None
    klucz_cache = f"{komenda}:{argument}"
    if klucz_cache in _cache_mxt:
        return _cache_mxt[klucz_cache]
    try:
        r = requests.get(
            f"https://api.mxtoolbox.com/api/v1/Lookup/{komenda}/{argument}",
            headers={"Authorization": MXTOOLBOX_KEY},
            timeout=12, verify=False
        )
        if r.status_code == 200:
            wynik = r.json()
            _cache_mxt[klucz_cache] = wynik
            return wynik
        _cache_mxt[klucz_cache] = None
        return None
    except Exception:
        return None

def mxt_blacklist_ip(ip):
    dane = _mxt_lookup("blacklist", ip)
    if dane is None:
        return {"zrodlo": "MXToolbox Blacklist", "wynik": "Brak klucza / błąd",
                "ocena": "BŁĄD", "szczegoły": "Brak klucza MXTOOLBOX_KEY lub błąd API"}
    failed   = dane.get("Failed", [])
    warnings = dane.get("Warnings", [])
    passed   = dane.get("Passed", [])
    total    = len(failed) + len(warnings) + len(passed)

    if failed:
        nazwy = ", ".join(f["Name"] for f in failed[:5])
        return {
            "zrodlo":    "MXToolbox Blacklist",
            "wynik":     f"{len(failed)}/{total} RBL",
            "ocena":     "ZŁOŚLIWY",
            "szczegoły": f"Na {len(failed)} blacklistach: {nazwy}"
        }
    if warnings:
        nazwy = ", ".join(w["Name"] for w in warnings[:3])
        return {
            "zrodlo":    "MXToolbox Blacklist",
            "wynik":     f"{len(warnings)} ostrzeżeń/{total} RBL",
            "ocena":     "PODEJRZANY",
            "szczegoły": f"Ostrzeżenia: {nazwy}"
        }
    return {
        "zrodlo":    "MXToolbox Blacklist",
        "wynik":     f"Czyste ({total} RBL)",
        "ocena":     "CZYSTY",
        "szczegoły": f"IP nie figuruje na żadnej z {total} sprawdzonych list RBL"
    }

def mxt_sprawdz_domene(domena, typ="spf"):
    d    = domena_glowna(domena)
    dane = _mxt_lookup(typ, d)
    if dane is None:
        return {"zrodlo": f"MXToolbox {typ.upper()}", "wynik": "Brak klucza / błąd",
                "ocena": "BŁĄD", "szczegoły": "Brak klucza MXTOOLBOX_KEY lub błąd API"}

    failed   = dane.get("Failed", [])
    warnings = dane.get("Warnings", [])

    if failed:
        info = " | ".join(f"{x['Name']}: {x.get('Info','')}" for x in failed[:3])
        return {
            "zrodlo":    f"MXToolbox {typ.upper()}",
            "wynik":     f"{len(failed)} błędów",
            "ocena":     "ZŁOŚLIWY",
            "szczegoły": info
        }
    if warnings:
        info = " | ".join(f"{x['Name']}: {x.get('Info','')}" for x in warnings[:3])
        return {
            "zrodlo":    f"MXToolbox {typ.upper()}",
            "wynik":     f"{len(warnings)} ostrzeżeń",
            "ocena":     "PODEJRZANY",
            "szczegoły": info
        }
    passed = dane.get("Passed", [])
    info   = " | ".join(x["Name"] for x in passed[:3]) if passed else "Brak danych"
    return {
        "zrodlo":    f"MXToolbox {typ.upper()}",
        "wynik":     "OK",
        "ocena":     "CZYSTY",
        "szczegoły": info
    }

def mxt_naglowki_auth(naglowki_tekst):
    if not MXTOOLBOX_KEY:
        return {"zrodlo": "MXToolbox Header", "wynik": "Brak klucza",
                "ocena": "BŁĄD", "szczegoły": "Wpisz MXTOOLBOX_KEY aby aktywować analizę nagłówków"}
    try:
        r = requests.post(
            "https://api.mxtoolbox.com/api/v1/Lookup/headeranalyzer/",
            headers={
                "Authorization": MXTOOLBOX_KEY,
                "Content-Type":  "application/json"
            },
            json={"headers": naglowki_tekst[:8000]},
            timeout=15, verify=False
        )
        if r.status_code == 200:
            dane     = r.json()
            failed   = dane.get("Failed", [])
            warnings = dane.get("Warnings", [])
            passed   = dane.get("Passed", [])
            if failed:
                info = " | ".join(f"{x['Name']}: {x.get('Info','')}" for x in failed[:4])
                return {"zrodlo": "MXToolbox Header", "wynik": f"{len(failed)} błędów",
                        "ocena": "ZŁOŚLIWY", "szczegoły": info}
            if warnings:
                info = " | ".join(f"{x['Name']}: {x.get('Info','')}" for x in warnings[:4])
                return {"zrodlo": "MXToolbox Header", "wynik": f"{len(warnings)} ostrzeżeń",
                        "ocena": "PODEJRZANY", "szczegoły": info}
            info = " | ".join(x["Name"] for x in passed[:4]) if passed else "Brak wyników"
            return {"zrodlo": "MXToolbox Header", "wynik": "OK",
                    "ocena": "CZYSTY", "szczegoły": info}
        elif r.status_code == 404:
            return {"zrodlo": "MXToolbox Header", "wynik": "Niedostępny w tym planie",
                    "ocena": "NIEZNANY",
                    "szczegoły": "Header Analyzer wymaga planu płatnego MXToolbox. Użyj lookupów SPF/DMARC."}
        return {"zrodlo": "MXToolbox Header", "wynik": f"HTTP {r.status_code}",
                "ocena": "BŁĄD", "szczegoły": f"Błąd API: {r.status_code}"}
    except Exception as e:
        return {"zrodlo": "MXToolbox Header", "wynik": str(e),
                "ocena": "BŁĄD", "szczegoły": "Błąd połączenia z MXToolbox"}

